{
  "name": "ber-viewer",
  "version": "1.2.build_34",
  "description": "BER Editor  — ETSI LI PS-PDU / 3GPP Lawful Intercept",
  "author": "LI Tools",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.litools.ber-viewer",
    "productName": "BER Viewer",
    "copyright": "LI Tools",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "asn1_patched/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  }
}
